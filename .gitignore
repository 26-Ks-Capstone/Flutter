app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# --- [보안 & 환경 변수] ---
# API 키나 비밀번호가 담긴 환경 변수 파일 (반드시 제외!)
.env
.env.*

# --- [안드로이드 특화] ---
# 로컬 SDK 경로 등 개인 환경 설정
/android/local.properties
.gradle/
captures/
*.keystore
*.jks
# 구글 서비스 설정 (Firebase 등을 쓸 때 필요함)
# /android/app/google-services.json

# --- [iOS/macOS 특화] ---
# 코코아팟 의존성 관련 (팀 정책에 따라 포함하기도 하지만 보통 제외)
.lsconnect
Pods/
DerivedData/
*.moved-aside
*.xcuserstate
# /ios/Runner/GoogleService-Info.plist

# --- [패키지 매니저 & 로그] ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- [기타 도구] ---
# 특정 에디터나 도구의 임시 파일
.project
.settings/
.vscode/  # (주석 해제 권장: 개인 설정이 팀원과 충돌할 수 있음)
